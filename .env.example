# ===== tiao — environment variables =====
# Copy these into Netlify (Site settings → Environment variables).
# NEVER commit real values. This file is only a template.

# --- PayPal (Apps & Credentials at https://developer.paypal.com) ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_ENV=sandbox           # use "live" when you go live
PAYPAL_CURRENCY=GBP

# --- CallMeBot WhatsApp group notification ---
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Add the CallMeBot number to your WhatsApp GROUP, then it replies with your apikey.
CALLMEBOT_PHONE=your-group-or-phone-id
CALLMEBOT_APIKEY=your-callmebot-apikey
