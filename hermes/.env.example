# ===== tiao hermes listener — environment =====
# Copy to .env (never commit .env). Fill in Supabase + WhatsApp.

# --- Supabase (required) ---
# Project Settings → API. Use the SERVICE ROLE key here (server-only, secret).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- WhatsApp (primary alert channel, self-hosted) ---
# Where to send alerts:
#   • your own number in international format, digits only, e.g. 447700900123
#   • or a GROUP JID like 12036303-1699999999@g.us
# Find a group's JID by running:  npm run wa-groups
WHATSAPP_TO=447700900123
# Optional: folder for the WhatsApp session (default: wa-auth). Git-ignored.
WA_AUTH_DIR=wa-auth

# --- Optional extra channels (any can run alongside WhatsApp) ---
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
# ntfy (self-hostable push): e.g. https://ntfy.sh/your-topic
NTFY_URL=
# Generic webhook: POSTs {text, order} to any endpoint hermes exposes
ALERT_WEBHOOK_URL=
# Shell command: gets the message on stdin + in $ORDER_TEXT
ALERT_COMMAND=
