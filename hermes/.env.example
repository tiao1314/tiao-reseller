# ===== tiao hermes listener — environment =====
# Copy to .env (never commit .env). Fill in Supabase + ONE alert channel.

# --- Supabase (required) ---
# Project Settings → API. Use the SERVICE ROLE key here (server-only, secret).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Alert channel: set whichever hermes uses (any one is enough) ---

# Telegram: create a bot with @BotFather → token; get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ntfy (self-hostable push, great for a home server): e.g. https://ntfy.sh/your-topic
NTFY_URL=

# Generic webhook: POSTs {text, order} — point this at hermes' own alert endpoint
ALERT_WEBHOOK_URL=

# Shell command: runs any command hermes already uses; gets the message on stdin
# and in $ORDER_TEXT (e.g. a notify-send / mail / custom script)
ALERT_COMMAND=
